# ════════════════════════════════════════════════════
#  EduAnalytics Backend — .env sozlamalari namunasi
#  Ushbu faylni .env deb nusxalang va to'ldiring:
#  copy .env.example .env    (Windows)
# ════════════════════════════════════════════════════

# 🔐 Django Secret Key — yangi kalit yaratish:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-very-secret-key-here-change-this

# 🛠 Ishlab chiqish rejimi
DEBUG=True

# 🌐 Ruxsat etilgan hostlar (vergul bilan ajrating)
ALLOWED_HOSTS=localhost,127.0.0.1

# 🗄 SQLite ishlatish (True=SQLite, False=PostgreSQL)
USE_SQLITE=True

# 🗄 PostgreSQL (USE_SQLITE=False bo'lganda)
# DATABASE_URL=postgres://user:password@localhost:5432/eduanalytics

# 🔑 JWT muddatlari
JWT_EXPIRE_HOURS=24
JWT_REFRESH_DAYS=7

# 🌍 CORS (vergul bilan ajrating)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# 🤖 ML Model yo'li (ixtiyoriy)
# MODEL_PATH=ml/models/model_v1.pkl

# 📋 Log darajasi
DJANGO_LOG_LEVEL=INFO
